# --- Database -------------------------------------------------------------
# On the server: reuse the existing Postgres instance, separate DB "finance".
# Host "postgres" is the container name on the shared "edge" docker network.
DATABASE_URL=postgres://finance:CHANGE_ME@postgres:5432/finance

# Base / reporting currency (everything is converted to this in reports)
BASE_CURRENCY=RUB

# --- AI (optional) --------------------------------------------------------
# Lemonade Server, OpenAI-compatible base URL (must reach the Windows host
# from inside the container). Leave EMPTY to disable AI parsing entirely —
# the app still works with manual entry.
# Example: http://host.docker.internal:8000/api/v1  (see README networking note)
LEMONADE_BASE_URL=
LEMONADE_MODEL=Qwen3-Coder-30B-A3B-Instruct-GGUF

# --- Container bootstrap --------------------------------------------------
# Run migrations / seed automatically on container start (idempotent).
AUTO_MIGRATE=true
AUTO_SEED=true

# --- Deploy ---------------------------------------------------------------
# Host port published on 127.0.0.1, exposed via tailscale serve.
# 8001 is used by the kitchen app, so finance defaults to 8002.
APP_PORT=8002
